{
  "name": "starter-blog",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "next dev",
    "dev": "contentlayer2 build && INIT_CWD=$PWD next dev",
    "build": "contentlayer2 build && INIT_CWD=$PWD next build && cross-env NODE_OPTIONS='--experimental-json-modules' node -r esbuild-register ./scripts/postbuild.mjs",
    "serve": "next start",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "content": "contentlayer2 dev",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "biome lint --write ."
  },
  "dependencies": {
    "@next/bundle-analyzer": "^13.5.0",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/typography": "^0.5.7",
    "autoprefixer": "^10.4.13",
    "contentlayer2": "^0.5.0",
    "esbuild": "0.14.38",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.2",
    "image-size": "1.0.0",
    "mdx-bundler": "^9.0.0",
    "next": "^13.5.0",
    "next-contentlayer2": "^0.5.0",
    "next-themes": "^0.2.0",
    "pliny": "^0.4.1",
    "postcss": "^8.4.16",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.0.0",
    "rehype-citation": "^2.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-preset-minify": "^7.0.0",
    "rehype-prism-plus": "^2.0.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "tailwindcss": "^3.2.2",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@svgr/webpack": "^6.3.1",
    "@types/react": "^18.0.18",
    "cross-env": "^7.0.3",
    "dedent": "^0.7.0",
    "esbuild-register": "3.3.3",
    "file-loader": "^6.0.0",
    "globby": "11.0.3",
    "husky": "^8.0.0",
    "js-yaml": "4.1.0",
    "lint-staged": "^13.0.0",
    "prettier": "^2.8.0",
    "typescript": "^5.3.0"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": ["biome check --write --no-errors-on-unmatched"]
  },
  "browserslist": ["> 0.5%", "last 2 versions", "not dead", "not ie 11"]
}
